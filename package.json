{
  "name": "onequote-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "OneQuote 统一管理仓库",
  "scripts": {
    "dev:vue": "pnpm --filter ./packages/onequote-vue dev",
    "dev:react": "pnpm --filter ./packages/onequote-react dev",
    "build:vue": "pnpm --filter ./packages/onequote-vue build",
    "build:react": "pnpm --filter ./packages/onequote-react build",
    "build:all": "pnpm -r build",
    "preview:vue": "pnpm --filter ./packages/onequote-vue preview",
    "preview:react": "pnpm --filter ./packages/onequote-react preview",
    "preview:all": "pnpm -r --parallel --filter ./packages/onequote-vue --filter ./packages/onequote-react preview",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "husky",
    "pre-commit": "nano-staged"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "medium-zoom": "^1.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@iconify-json/ri": "^1.2.10",
    "@types/node": "^24.10.1",
    "@unocss/postcss": "^66.6.7",
    "@unocss/preset-web-fonts": "^66.6.7",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.3",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0",
    "postcss": "^8.5.8",
    "typescript": "~5.9.3",
    "unocss": "^66.6.7",
    "vite": "^7.3.1"
  },
  "nano-staged": {
    "*": "eslint --fix"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11",
    "iOS >= 12",
    "Android >= 8"
  ]
}